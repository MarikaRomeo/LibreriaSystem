@page "/books/{Id:int}"
@using LibrarySystem.Core
@using LibrarySystem.Data
@using LibrarySystem.Web.ViewModels.Loans
@using Microsoft.EntityFrameworkCore
@inject LibraryContext Context
@inject NavigationManager Navigation

<PageTitle>Bokdetaljer</PageTitle>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(statusIsError ? "alert-danger" : "alert-success")" role="alert">
        @statusMessage
    </div>
}

@if (book is null)
{
    <p>Laddar...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">@book.Title</h3>
            <p class="text-muted mb-0">@book.Author</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToBooks">Till boklistan</button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3"><strong>ISBN:</strong> @book.ISBN</div>
                <div class="col-md-3"><strong>Utgivningsår:</strong> @book.PublishedYear</div>
                <div class="col-md-3"><strong>Status:</strong> @(book.IsAvailable ? "Tillgänglig" : "Utlånad")</div>
                <div class="col-md-3 d-flex justify-content-end gap-2">
                    @if (book.IsAvailable)
                    {
                        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="ShowCreateForm">Nytt lån</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary btn-sm" @onclick="ReturnActiveLoanAsync">Returnera aktivt lån</button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (isFormVisible)
    {
        <EditForm Model="loanForm" OnValidSubmit="CreateLoanAsync" class="card shadow-sm mb-4">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="card-body">
                <h5 class="card-title">Skapa nytt lån</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Medlem</label>
                        <InputSelect class="form-select" @bind-Value="loanForm.MemberId">
                            <option value="0">Välj medlem</option>
                            @foreach (var member in memberOptions)
                            {
                                <option value="@member.Id">@member.FullName</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => loanForm.MemberId)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Utlåningsdatum</label>
                        <InputDate class="form-control" @bind-Value="loanForm.LoanDate" />
                        <ValidationMessage For="@(() => loanForm.LoanDate)" />
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <button type="submit" class="btn btn-primary">Skapa lån</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="HideForm">Avbryt</button>
            </div>
        </EditForm>
    }

    <h5>Lånehistorik</h5>
    @if (loanHistory.Count == 0)
    {
        <p>Ingen lånehistorik finns ännu.</p>
    }
    else
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Medlem</th>
                    <th>Utlånad</th>
                    <th>Returnerad</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in loanHistory)
                {
                    <tr>
                        <td>@loan.Member.FirstName @loan.Member.LastName</td>
                        <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                        <td>@(loan.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(loan.IsReturned ? "Returnerad" : "Aktiv")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Book? book;
    private List<Loan> loanHistory = [];
    private List<MemberOption> memberOptions = [];
    private LoanFormModel loanForm = new();
    private string? statusMessage;
    private bool statusIsError;
    private bool isFormVisible;

    protected override async Task OnParametersSetAsync()
    {
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        book = await Context.Books.FirstOrDefaultAsync(item => item.Id == Id);
        loanHistory = await Context.Loans
            .Include(loan => loan.Member)
            .Where(loan => loan.BookId == Id)
            .OrderByDescending(loan => loan.LoanDate)
            .ToListAsync();

        memberOptions = await Context.Members
            .OrderBy(member => member.LastName)
            .ThenBy(member => member.FirstName)
            .Select(member => new MemberOption
            {
                Id = member.Id,
                FullName = member.FirstName + " " + member.LastName
            })
            .ToListAsync();
    }

    private async Task CreateLoanAsync()
    {
        ClearStatus();

        if (book is null)
        {
            SetError("Boken kunde inte hittas.");
            return;
        }

        var member = await Context.Members.FindAsync(loanForm.MemberId);

        if (member is null)
        {
            SetError("Medlemmen kunde inte hittas.");
            await LoadPageDataAsync();
            return;
        }

        if (!book.IsAvailable)
        {
            SetError("Boken är redan utlånad.");
            await LoadPageDataAsync();
            return;
        }

        Context.Loans.Add(new Loan
        {
            BookId = book.Id,
            MemberId = member.Id,
            LoanDate = loanForm.LoanDate
        });

        book.IsAvailable = false;
        await Context.SaveChangesAsync();
        await LoadPageDataAsync();
        HideForm();
        statusMessage = "Lånet skapades.";
    }

    private async Task ReturnActiveLoanAsync()
    {
        ClearStatus();

        if (book is null)
        {
            SetError("Boken kunde inte hittas.");
            return;
        }

        var activeLoan = await Context.Loans
            .FirstOrDefaultAsync(loan => loan.BookId == Id && loan.ReturnDate == null);

        if (activeLoan is null)
        {
            SetError("Det finns inget aktivt lån att returnera.");
            return;
        }

        activeLoan.ReturnDate = DateTime.Today;
        book.IsAvailable = true;
        await Context.SaveChangesAsync();
        await LoadPageDataAsync();
        statusMessage = "Det aktiva lånet markerades som returnerat.";
    }

    private void ShowCreateForm()
    {
        isFormVisible = true;
        ResetLoanForm();
    }

    private void HideForm()
    {
        isFormVisible = false;
        ResetLoanForm();
    }

    private void ResetLoanForm()
    {
        loanForm = new LoanFormModel
        {
            BookId = Id,
            LoanDate = DateTime.Today
        };
    }

    private void BackToBooks()
    {
        Navigation.NavigateTo("/books");
    }

    private void ClearStatus()
    {
        statusMessage = null;
        statusIsError = false;
    }

    private void SetError(string message)
    {
        statusMessage = message;
        statusIsError = true;
    }
}
