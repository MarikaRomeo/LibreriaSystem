@page "/loan"
@page "/loans"
@using LoanEntity = LibrarySystem.Core.Loan
@using LibrarySystem.Data
@using LibrarySystem.Web.ViewModels.Loans
@using Microsoft.EntityFrameworkCore
@inject LibraryContext Context

<PageTitle>Utlåning</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Utlåning</h3>
    <button class="btn btn-outline-secondary" @onclick="ShowCreateForm">Nytt lån</button>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(statusIsError ? "alert-danger" : "alert-success")" role="alert">
        @statusMessage
    </div>
}

@if (isFormVisible)
{
    <EditForm Model="loanForm" OnValidSubmit="CreateLoanAsync" class="card shadow-sm mb-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="card-body">
            <h5 class="card-title">Skapa nytt lån</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Bok</label>
                    <InputSelect class="form-select" @bind-Value="loanForm.BookId">
                        <option value="0">Välj bok</option>
                        @foreach (var book in availableBooks)
                        {
                            <option value="@book.Id">@book.Title (@book.Author)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => loanForm.BookId)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Medlem</label>
                    <InputSelect class="form-select" @bind-Value="loanForm.MemberId">
                        <option value="0">Välj medlem</option>
                        @foreach (var member in memberOptions)
                        {
                            <option value="@member.Id">@member.FullName</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => loanForm.MemberId)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Utlåningsdatum</label>
                    <InputDate class="form-control" @bind-Value="loanForm.LoanDate" />
                    <ValidationMessage For="@(() => loanForm.LoanDate)" />
                </div>
            </div>
        </div>
        <div class="card-footer d-flex gap-2">
            <button type="submit" class="btn btn-primary">Skapa lån</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="HideForm">Avbryt</button>
        </div>
    </EditForm>
}

@if (loans == null)
{
    <p>Laddar...</p>
}
else if (loans.Count == 0)
{
    <p>Inga aktiva eller historiska lån hittades.</p>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Bok</th>
                <th>Medlem</th>
                <th>Utlånad</th>
                <th>Returnerad</th>
                <th>Status</th>
                <th>Överfällig</th>
                <th class="text-end">Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in loans)
            {
                <tr class="@(IsOverdue(loan) ? "table-danger" : string.Empty)">
                    <td>@loan.Book.Title</td>
                    <td>@loan.Member.FirstName @loan.Member.LastName</td>
                    <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                    <td>@(loan.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>@(loan.IsReturned ? "Returnerad" : "Aktiv")</td>
                    <td>
                        @if (IsOverdue(loan))
                        {
                            <span class="badge text-bg-danger">Ja</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Nej</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            @if (!loan.IsReturned)
                            {
                                <button class="btn btn-outline-primary" @onclick="() => ReturnLoanAsync(loan.Id)">Returnera</button>
                            }
                            <button class="btn btn-outline-danger" @onclick="() => DeleteLoanAsync(loan.Id)">Ta bort</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<LoanEntity>? loans;
    private List<BookOption> availableBooks = [];
    private List<MemberOption> memberOptions = [];
    private LoanFormModel loanForm = new();
    private string? statusMessage;
    private bool statusIsError;
    private bool isFormVisible;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        loans = await Context.Loans
            .Include(loan => loan.Book)
            .Include(loan => loan.Member)
            .OrderByDescending(loan => loan.LoanDate)
            .ToListAsync();

        availableBooks = await Context.Books
            .Where(book => book.IsAvailable)
            .OrderBy(book => book.Title)
            .Select(book => new BookOption
            {
                Id = book.Id,
                Title = book.Title,
                Author = book.Author
            })
            .ToListAsync();

        memberOptions = await Context.Members
            .OrderBy(member => member.LastName)
            .ThenBy(member => member.FirstName)
            .Select(member => new MemberOption
            {
                Id = member.Id,
                FullName = member.FirstName + " " + member.LastName
            })
            .ToListAsync();
    }

    private async Task CreateLoanAsync()
    {
        ClearStatus();

        var book = await Context.Books.FindAsync(loanForm.BookId);
        var member = await Context.Members.FindAsync(loanForm.MemberId);

        if (book is null || member is null)
        {
            SetError("Bok eller medlem kunde inte hittas.");
            await LoadPageDataAsync();
            return;
        }

        if (!book.IsAvailable)
        {
            SetError("Boken är redan utlånad.");
            await LoadPageDataAsync();
            return;
        }

        Context.Loans.Add(new LoanEntity
        {
            BookId = book.Id,
            MemberId = member.Id,
            LoanDate = loanForm.LoanDate
        });

        book.IsAvailable = false;

        await Context.SaveChangesAsync();
        await LoadPageDataAsync();
        HideForm();
        statusMessage = "Lånet skapades.";
    }

    private async Task ReturnLoanAsync(int loanId)
    {
        ClearStatus();

        var loan = await Context.Loans
            .Include(item => item.Book)
            .FirstOrDefaultAsync(item => item.Id == loanId);

        if (loan is null)
        {
            SetError("Lånet kunde inte hittas.");
            return;
        }

        if (loan.IsReturned)
        {
            SetError("Lånet är redan returnerat.");
            return;
        }

        loan.ReturnDate = DateTime.Today;
        loan.Book.IsAvailable = true;

        await Context.SaveChangesAsync();
        await LoadPageDataAsync();
        statusMessage = "Boken markerades som returnerad.";
    }

    private async Task DeleteLoanAsync(int loanId)
    {
        ClearStatus();

        var loan = await Context.Loans
            .Include(item => item.Book)
            .FirstOrDefaultAsync(item => item.Id == loanId);

        if (loan is null)
        {
            SetError("Lånet kunde inte hittas.");
            return;
        }

        if (!loan.IsReturned)
        {
            loan.Book.IsAvailable = true;
        }

        Context.Loans.Remove(loan);
        await Context.SaveChangesAsync();
        await LoadPageDataAsync();
        statusMessage = "Lånet togs bort.";
    }

    private void ShowCreateForm()
    {
        isFormVisible = true;
        ResetLoanForm();
    }

    private void HideForm()
    {
        isFormVisible = false;
        ResetLoanForm();
    }

    private void ResetLoanForm()
    {
        loanForm = new LoanFormModel
        {
            LoanDate = DateTime.Today
        };
    }

    private void ClearStatus()
    {
        statusMessage = null;
        statusIsError = false;
    }

    private void SetError(string message)
    {
        statusMessage = message;
        statusIsError = true;
    }

    private static bool IsOverdue(LoanEntity loan)
    {
        return !loan.IsReturned && loan.LoanDate.Date < DateTime.Today.AddDays(-14);
    }
}
