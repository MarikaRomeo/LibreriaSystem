@page "/books"
@using LibrarySystem.Core
@using LibrarySystem.Data
@using LibrarySystem.Web.ViewModels.Books
@using Microsoft.EntityFrameworkCore
@inject LibraryContext Context
@inject NavigationManager Navigation

<PageTitle>Böcker</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Böcker</h3>
    <button type="button" class="btn btn-outline-secondary" @onclick="ShowCreateForm">Ny bok</button>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-7">
        <label class="form-label">Sök</label>
        <input class="form-control" value="@searchTerm" @oninput="OnSearchInput" placeholder="Sök på ISBN, titel eller författare" />
    </div>
    <div class="col-md-5 d-flex align-items-end">
        <div class="d-flex gap-2 w-100">
            <button type="button" class="btn btn-outline-primary" @onclick="ApplyFiltersAsync">Sök</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="ResetFiltersAsync">Rensa sökning</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(statusIsError ? "alert-danger" : "alert-success")" role="alert">
        @statusMessage
    </div>
}

@if (isFormVisible)
{
    <EditForm Model="bookForm" OnValidSubmit="SaveBookAsync" class="card shadow-sm mb-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="card-body">
            <h5 class="card-title">@(bookForm.Id == 0 ? "Lägg till bok" : "Redigera bok")</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">ISBN</label>
                    <InputText class="form-control" @bind-Value="bookForm.ISBN" />
                    <ValidationMessage For="@(() => bookForm.ISBN)" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Titel</label>
                    <InputText class="form-control" @bind-Value="bookForm.Title" />
                    <ValidationMessage For="@(() => bookForm.Title)" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Författare</label>
                    <InputText class="form-control" @bind-Value="bookForm.Author" />
                    <ValidationMessage For="@(() => bookForm.Author)" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Utgivningsår</label>
                    <InputNumber class="form-control" @bind-Value="bookForm.PublishedYear" />
                    <ValidationMessage For="@(() => bookForm.PublishedYear)" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="bookForm.IsAvailable" />
                        <label class="form-check-label">Tillgänglig</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer d-flex gap-2">
            <button type="submit" class="btn btn-primary">Spara</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="HideForm">Avbryt</button>
        </div>
    </EditForm>
}

@if (books == null)
{
    <p>Laddar...</p>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SortByAsync(nameof(Book.ISBN))">ISBN @SortIndicator(nameof(Book.ISBN))</button></th>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SortByAsync(nameof(Book.Title))">Titel @SortIndicator(nameof(Book.Title))</button></th>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SortByAsync(nameof(Book.Author))">Författare @SortIndicator(nameof(Book.Author))</button></th>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SortByAsync(nameof(Book.PublishedYear))">År @SortIndicator(nameof(Book.PublishedYear))</button></th>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none" @onclick="() => SortByAsync(nameof(Book.IsAvailable))">Status @SortIndicator(nameof(Book.IsAvailable))</button></th>
                <th class="text-end">Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.ISBN</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.PublishedYear</td>
                    <td>@(book.IsAvailable ? "Tillgänglig" : "Utlånad")</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => OpenBookDetails(book.Id)">Detaljer</button>
                            <button type="button" class="btn btn-outline-primary" @onclick="() => EditBook(book)">Redigera</button>
                            <button type="button" class="btn btn-outline-danger" @onclick="() => DeleteBookAsync(book.Id)">Ta bort</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Book>? books;
    private BookFormModel bookForm = new();
    private string? statusMessage;
    private bool statusIsError;
    private bool isFormVisible;
    private string searchTerm = string.Empty;
    private string sortColumn = nameof(Book.Title);
    private bool sortAscending = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        IQueryable<Book> query = Context.Books;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var trimmedSearchTerm = searchTerm.Trim();
            var normalizedSearchTerm = trimmedSearchTerm.ToLower();
            var matchesAvailableStatus =
                "tillgänglig".Contains(normalizedSearchTerm) ||
                "tillganglig".Contains(normalizedSearchTerm) ||
                "available".Contains(normalizedSearchTerm);
            var matchesBorrowedStatus =
                "utlånad".Contains(normalizedSearchTerm) ||
                "utlanad".Contains(normalizedSearchTerm) ||
                "borrowed".Contains(normalizedSearchTerm);

            query = query.Where(book =>
                book.ISBN.Contains(trimmedSearchTerm) ||
                book.Title.Contains(trimmedSearchTerm) ||
                book.Author.Contains(trimmedSearchTerm) ||
                (book.IsAvailable && matchesAvailableStatus) ||
                (!book.IsAvailable && matchesBorrowedStatus));
        }

        query = sortColumn switch
        {
            nameof(Book.ISBN) => sortAscending ? query.OrderBy(book => book.ISBN) : query.OrderByDescending(book => book.ISBN),
            nameof(Book.Author) => sortAscending ? query.OrderBy(book => book.Author) : query.OrderByDescending(book => book.Author),
            nameof(Book.PublishedYear) => sortAscending ? query.OrderBy(book => book.PublishedYear) : query.OrderByDescending(book => book.PublishedYear),
            nameof(Book.IsAvailable) => sortAscending ? query.OrderBy(book => book.IsAvailable) : query.OrderByDescending(book => book.IsAvailable),
            _ => sortAscending ? query.OrderBy(book => book.Title) : query.OrderByDescending(book => book.Title)
        };

        books = await query.ToListAsync();
    }

    private async Task SaveBookAsync()
    {
        ClearStatus();

        if (bookForm.Id == 0)
        {
            var book = new Book
            {
                ISBN = bookForm.ISBN.Trim(),
                Title = bookForm.Title.Trim(),
                Author = bookForm.Author.Trim(),
                PublishedYear = bookForm.PublishedYear,
                IsAvailable = bookForm.IsAvailable
            };

            Context.Books.Add(book);
            statusMessage = "Boken lades till.";
        }
        else
        {
            var book = await Context.Books.FindAsync(bookForm.Id);
            if (book is null)
            {
                SetError("Boken kunde inte hittas.");
                await LoadBooksAsync();
                ResetForm();
                return;
            }

            book.ISBN = bookForm.ISBN.Trim();
            book.Title = bookForm.Title.Trim();
            book.Author = bookForm.Author.Trim();
            book.PublishedYear = bookForm.PublishedYear;
            book.IsAvailable = bookForm.IsAvailable;

            statusMessage = "Boken uppdaterades.";
        }

        await Context.SaveChangesAsync();
        await LoadBooksAsync();
        HideForm();
    }

    private void EditBook(Book book)
    {
        ClearStatus();
        isFormVisible = true;
        bookForm = new BookFormModel
        {
            Id = book.Id,
            ISBN = book.ISBN,
            Title = book.Title,
            Author = book.Author,
            PublishedYear = book.PublishedYear,
            IsAvailable = book.IsAvailable
        };
    }

    private async Task DeleteBookAsync(int id)
    {
        ClearStatus();

        var book = await Context.Books
            .Include(item => item.Loans)
            .FirstOrDefaultAsync(item => item.Id == id);

        if (book is null)
        {
            SetError("Boken kunde inte hittas.");
            return;
        }

        if (book.Loans.Count > 0)
        {
            SetError("Boken kan inte tas bort eftersom den har lånehistorik.");
            return;
        }

        Context.Books.Remove(book);
        await Context.SaveChangesAsync();
        await LoadBooksAsync();
        HideForm();
        statusMessage = "Boken togs bort.";
    }

    private void OpenBookDetails(int id)
    {
        Navigation.NavigateTo($"/books/{id}");
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadBooksAsync();
    }

    private void OnSearchInput(ChangeEventArgs args)
    {
        searchTerm = args.Value?.ToString() ?? string.Empty;
    }

    private async Task ResetFiltersAsync()
    {
        searchTerm = string.Empty;
        sortColumn = nameof(Book.Title);
        sortAscending = true;
        await LoadBooksAsync();
    }

    private async Task SortByAsync(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }

        await LoadBooksAsync();
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column)
        {
            return string.Empty;
        }

        return sortAscending ? "↑" : "↓";
    }

    private void ShowCreateForm()
    {
        isFormVisible = true;
        ResetForm();
    }

    private void HideForm()
    {
        isFormVisible = false;
        ResetForm();
    }

    private void ResetForm()
    {
        bookForm = new BookFormModel
        {
            PublishedYear = DateTime.Today.Year,
            IsAvailable = true
        };
    }

    private void ClearStatus()
    {
        statusMessage = null;
        statusIsError = false;
    }

    private void SetError(string message)
    {
        statusMessage = message;
        statusIsError = true;
    }
}
