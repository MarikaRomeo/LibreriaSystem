@using LibrarySystem.Core
@using LibrarySystem.Data
@using Microsoft.EntityFrameworkCore

@page "/members"
@inject LibraryContext Context

<PageTitle>Medlemmar</PageTitle>

<h3>Medlemmar</h3>

@if (members == null)
{
    <p>Laddar...</p>
}
else if (members.Count == 0)
{
    <p>Inga medlemmar hittades.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Namn</th>
                <th>E-post</th>
                <th>Medlem sedan</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in members)
            {
                <tr>
                    <td>@member.FirstName @member.LastName</td>
                    <td>@member.Email</td>
                    <td>@member.MembershipDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Member>? members;

    protected override async Task OnInitializedAsync()
    {
        members = await Context.Members.ToListAsync();
    }
}
