@using LibrarySystem.Core

<div class="card shadow-sm h-100 book-card @(Book.IsAvailable ? "border-success-subtle" : "border-warning-subtle")">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <h5 class="card-title mb-0">@Book.Title</h5>
            <span class="badge @(Book.IsAvailable ? "text-bg-success" : "text-bg-warning")">
                @(Book.IsAvailable ? "Tillgänglig" : "Utlånad")
            </span>
        </div>
        <p class="text-muted mb-2">@Book.Author</p>
        <p class="mb-1"><strong>ISBN:</strong> @Book.ISBN</p>
        <p class="mb-0"><strong>Utgivningsår:</strong> @Book.PublishedYear</p>
    </div>
</div>

@code {
    [Parameter]
    public Book Book { get; set; } = default!;
}
